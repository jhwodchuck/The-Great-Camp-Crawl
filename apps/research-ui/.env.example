# Shared
RESEARCH_UI_SECRET=replace-with-a-long-random-secret

# Use Postgres on Vercel. Vercel Postgres / Neon credentials fit here directly.
RESEARCH_UI_DATABASE_URL=postgresql://user:password@host:5432/database

# Parent access: choose one safe bootstrap path for deployment.
RESEARCH_UI_BOOTSTRAP_PARENT_USERNAME=parent
RESEARCH_UI_BOOTSTRAP_PARENT_PASSWORD=replace-with-a-strong-password
RESEARCH_UI_BOOTSTRAP_PARENT_DISPLAY_NAME=Parent
# Or use an invite code instead of a bootstrap account:
# RESEARCH_UI_PARENT_INVITE_CODE=replace-with-a-secret-invite-code
# RESEARCH_UI_ALLOW_UNINVITED_FIRST_PARENT=false

# Local development defaults
RESEARCH_UI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RESEARCH_UI_ENABLE_FILE_EXPORTS=true
RESEARCH_UI_EXPORT_DIR=data/staging/contributions
NEXT_PUBLIC_API_URL=http://localhost:8000
